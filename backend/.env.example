# Скопируйте в .env и измените значения перед деплоем.
# setup.ps1 создаст .env автоматически при первом запуске.

# Обязательно смените в production (минимум 50 символов):
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret-key

# true — только для локальной разработки
DJANGO_DEBUG=true

# Разрешённые домены через запятую (без пробелов)
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,kavkazkamen.ru,www.kavkazkamen.ru,admin.kavkazkamen.ru

# Origins фронтенда для CORS и CSRF
CORS_ALLOWED_ORIGINS=http://127.0.0.1:4000,http://localhost:4000,https://kavkazkamen.ru,https://www.kavkazkamen.ru,https://admin.kavkazkamen.ru

# Никогда не включайте в production
CORS_ALLOW_ALL=false

# HTTPS-редирект в production (при DEBUG=false)
SECURE_SSL_REDIRECT=true

# Публичный адрес сайта для sitemap.xml и robots.txt
SITE_URL=https://kavkazkamen.ru
